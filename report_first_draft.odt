   </text:sequence-decls>
   <text:h text:style-name="Heading_20_1" text:outline-level="1"><text:span text:style-name="Strong_20_Emphasis">Design and Testing Document – Student Grade Calculator (SGC)</text:span></text:h>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">1. Introduction</text:span></text:h>
   <text:p text:style-name="Text_20_body">The Student Grade Calculator (SGC) is a Java-based command-line application designed to manage and compute academic performance for university students. It retrieves student, module, and assessment data from an SQLite database and calculates module grades and overall degree classifications.</text:p>
   <text:p text:style-name="Text_20_body">The purpose of the application is to:</text:p>
   <text:list xml:id="list34938455" text:style-name="L7">
    <text:list-item>
     <text:p text:style-name="P15">Provide detailed assessment-level information </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P15">Calculate module grades based on weighted assessments </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P14">Compute final degree classification using academic rules </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Key Functionalities</text:span></text:h>
   <text:list xml:id="list3258989252" text:style-name="L8">
    <text:list-item>
     <text:p text:style-name="P17">Load student data dynamically from a database </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P17">View individual assessment results </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P17">Calculate module grades using weighted contributions </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P17">Compute overall degree score and classification </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P16">Provide an interactive CLI for user navigation </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">2. Class Diagrams (Textual UML Representation)</text:span></text:h>
   <text:section text:style-name="Sect1" text:name="code-block-viewer">
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| <text:s text:c="4"/>Assessment <text:s text:c="6"/>| &lt;&lt;abstract&gt;&gt;</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - assessmentID <text:s text:c="6"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - type <text:s text:c="14"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - moduleID <text:s text:c="10"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - awardedMarks <text:s text:c="6"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - weight <text:s text:c="12"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| + getGrade() <text:s text:c="8"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| + getContribution() <text:s/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>+----------+-----------+</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="27"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="8"/>---------------------------------------</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="8"/>| <text:s text:c="36"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+---------------+ <text:s text:c="18"/>+------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s text:c="4"/>Exam <text:s text:c="5"/>| <text:s text:c="18"/>| <text:s text:c="2"/>Coursework <text:s text:c="4"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+---------------+ <text:s text:c="18"/>+------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - maxMarks <text:s text:c="3"/>| <text:s text:c="18"/>| (no extra fields)|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+---------------+ <text:s text:c="18"/>+------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s text:c="6"/>Module <text:s text:c="8"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - moduleID <text:s text:c="10"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - level <text:s text:c="13"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - assessments[] <text:s text:c="5"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:soft-page-break/>| - cachedScore <text:s text:c="7"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + getModuleScore() <text:s text:c="2"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + addAssessment() <text:s text:c="3"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s text:c="6"/>Student <text:s text:c="7"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - studentID <text:s text:c="9"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - modules[] <text:s text:c="9"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + getDegreeScore() <text:s text:c="2"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + getDegreeClass() <text:s text:c="2"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s/>DegreeCalculator <text:s text:c="3"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + calculateScore() <text:s text:c="2"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + classify() <text:s text:c="8"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s text:c="4"/>DegreeClass <text:s text:c="5"/>| &lt;&lt;enum&gt;&gt;</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| FAIL, THIRD, etc. <text:s text:c="3"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
   </text:section>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">3. Class Descriptions</text:span></text:h>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">SGC (Main Logic Class)</text:span></text:h>
   <text:p text:style-name="Text_20_body">Acts as the core system container. It holds all nested classes and database interaction methods. Responsible for loading student data from SQLite.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Assessment (Abstract Class)</text:span></text:h>
   <text:p text:style-name="Text_20_body">Defines a general structure for all assessments. It enforces implementation of:</text:p>
   <text:list xml:id="list2280601811" text:style-name="L9">
    <text:list-item>
     <text:p text:style-name="P19"><text:span text:style-name="Source_20_Text">getGrade()</text:span> </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P18"><text:span text:style-name="Source_20_Text">getContribution()</text:span> </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Text_20_body">This ensures consistency across different assessment types.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Exam</text:span></text:h>
   <text:p text:style-name="Text_20_body">Extends <text:span text:style-name="Source_20_Text">Assessment</text:span>. Represents exam-based grading where marks must be converted into a percentage using maximum marks.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Coursework</text:span></text:h>
   <text:p text:style-name="Text_20_body">Extends <text:span text:style-name="Source_20_Text">Assessment</text:span>. Represents coursework where marks are already in percentage form.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Module</text:span></text:h>
   <text:p text:style-name="Text_20_body">Represents a university module containing multiple assessments.</text:p>
   <text:list xml:id="list624881956" text:style-name="L10">
    <text:list-item>
     <text:p text:style-name="P21">Calculates total grade using weighted contributions </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P20"><text:soft-page-break/>Implements caching (<text:span text:style-name="Source_20_Text">cachedScore</text:span>) for performance optimization </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Student</text:span></text:h>
   <text:p text:style-name="Text_20_body">Represents a student with multiple modules.</text:p>
   <text:list xml:id="list1586290384" text:style-name="L11">
    <text:list-item>
     <text:p text:style-name="P23">Provides methods to calculate degree score and classification </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P22">Acts as a container for module data </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">DegreeCalculator</text:span></text:h>
   <text:p text:style-name="Text_20_body">Contains static logic for:</text:p>
   <text:list xml:id="list307491706" text:style-name="L12">
    <text:list-item>
     <text:p text:style-name="P25">Calculating final degree score </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P25">Applying weighting rules (30% Level 5, 70% Level 6) </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P24">Dropping the lowest module </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">DegreeClass (Enum)</text:span></text:h>
   <text:p text:style-name="Text_20_body">Defines classification boundaries:</text:p>
   <text:list xml:id="list2705182264" text:style-name="L13">
    <text:list-item>
     <text:p text:style-name="P26">Fail, Third, 2:2, 2:1, First<text:line-break/>Encapsulates classification logic and descriptions. </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Main</text:span></text:h>
   <text:p text:style-name="Text_20_body">Handles CLI interaction:</text:p>
   <text:list xml:id="list928089523" text:style-name="L14">
    <text:list-item>
     <text:p text:style-name="P28">User input validation </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P28">Menu navigation </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P27">Displaying formatted outputs </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">4. OOP Principles</text:span></text:h>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Encapsulation</text:span></text:h>
   <text:p text:style-name="Text_20_body">All class fields are private or protected and accessed via getters.<text:line-break/>Example:</text:p>
   <text:list xml:id="list3905013598" text:style-name="L15">
    <text:list-item>
     <text:p text:style-name="P30"><text:span text:style-name="Source_20_Text">Student</text:span> hides its module list </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P29"><text:span text:style-name="Source_20_Text">Module</text:span> controls how assessments are added </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Text_20_body">This prevents unintended modification of internal state.</text:p>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Inheritance</text:span></text:h>
   <text:p text:style-name="Text_20_body"><text:span text:style-name="Source_20_Text">Exam</text:span> and <text:span text:style-name="Source_20_Text">Coursework</text:span> inherit from <text:span text:style-name="Source_20_Text">Assessment</text:span>.</text:p>
   <text:p text:style-name="Text_20_body">Benefits:</text:p>
   <text:list xml:id="list59798765" text:style-name="L16">
    <text:list-item>
     <text:p text:style-name="P32">Code reuse </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P32"><text:soft-page-break/>Shared structure </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P31">Consistent interface </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Polymorphism</text:span></text:h>
   <text:p text:style-name="Text_20_body">The system treats all assessments uniformly:</text:p>
   <text:section text:style-name="Sect1" text:name="Section1">
    <text:p text:style-name="Preformatted_20_Text"><text:bookmark text:name="code-block-viewer"/>for (Assessment a : assessments)</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="4"/>total += a.getContribution();</text:p>
   </text:section>
   <text:p text:style-name="Text_20_body">Even though <text:span text:style-name="Source_20_Text">Exam</text:span> and <text:span text:style-name="Source_20_Text">Coursework</text:span> calculate differently, they are used interchangeably.</text:p>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Abstraction</text:span></text:h>
   <text:p text:style-name="Text_20_body"><text:span text:style-name="Source_20_Text">Assessment</text:span> is abstract and hides implementation details.<text:line-break/>Users of the class do not need to know:</text:p>
   <text:list xml:id="list13473862" text:style-name="L17">
    <text:list-item>
     <text:p text:style-name="P34">How grades are calculated </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P33">Whether it is an exam or coursework </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">5. CLI Design</text:span></text:h>
   <text:p text:style-name="Text_20_body">The application uses a menu-driven command-line interface.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">User Flow</text:span></text:h>
   <text:list xml:id="list1773868710" text:style-name="L18">
    <text:list-item>
     <text:p text:style-name="P36">User enters Student ID (validated against database) </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P36">Menu options: </text:p>
     <text:list>
      <text:list-item>
       <text:p text:style-name="P36">Assessment view </text:p>
      </text:list-item>
      <text:list-item>
       <text:p text:style-name="P36">Module view </text:p>
      </text:list-item>
      <text:list-item>
       <text:p text:style-name="P36">Degree classification </text:p>
      </text:list-item>
     </text:list>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P35">User selects an option and inputs relevant IDs </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Module View Enhancement</text:span></text:h>
   <text:p text:style-name="Text_20_body">The system displays available module ranges grouped by level:</text:p>
   <text:section text:style-name="Sect1" text:name="Section2">
    <text:p text:style-name="Preformatted_20_Text"><text:bookmark text:name="code-block-viewer1"/>Available Modules:</text:p>
    <text:p text:style-name="Preformatted_20_Text">Level 5: 5001 - 5010</text:p>
    <text:p text:style-name="Preformatted_20_Text">Level 6: 6001 - 6012</text:p>
    <text:p text:style-name="Preformatted_20_Text">Enter Module ID:</text:p>
   </text:section>
   <text:p text:style-name="Text_20_body">This improves usability by guiding valid input.</text:p>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">User Input</text:span></text:h>
   <text:list xml:id="list3538018900" text:style-name="L19">
    <text:list-item>
     <text:p text:style-name="P38">Student ID </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P38">Assessment ID </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P38"><text:soft-page-break/>Module ID </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P37">Menu choices </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Text_20_body">Validation includes:</text:p>
   <text:list xml:id="list3697126074" text:style-name="L20">
    <text:list-item>
     <text:p text:style-name="P40">Numeric parsing </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P40">Range checks </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P39">Existence checks </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Output</text:span></text:h>
   <text:p text:style-name="Text_20_body">Formatted tables displaying:</text:p>
   <text:list xml:id="list350190394" text:style-name="L21">
    <text:list-item>
     <text:p text:style-name="P42">Assessment details </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P42">Module grades </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P41">Degree classification (color-coded) </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">Testing</text:span></text:h>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">1. Testing Strategy</text:span></text:h>
   <text:p text:style-name="Text_20_body">The application was tested using a combination of:</text:p>
   <text:list xml:id="list2939459219" text:style-name="L22">
    <text:list-item>
     <text:p text:style-name="P44"><text:span text:style-name="Strong_20_Emphasis">Unit testing (manual)</text:span> for individual methods </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P44"><text:span text:style-name="Strong_20_Emphasis">Integration testing</text:span> for database interaction </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P43"><text:span text:style-name="Strong_20_Emphasis">User input testing</text:span> for CLI robustness </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Text_20_body">Focus areas:</text:p>
   <text:list xml:id="list2942120831" text:style-name="L23">
    <text:list-item>
     <text:p text:style-name="P46">Correct grade calculations </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P46">Handling missing/null data </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P46">Input validation </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P45">Database query correctness </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">2. Test Cases</text:span></text:h>
   <table:table table:name="Table1" table:style-name="Table1">
    <table:table-column table:style-name="Table1.A"/>
    <table:table-column table:style-name="Table1.B"/>
    <table:table-column table:style-name="Table1.C"/>
    <table:table-header-rows>
     <table:table-row>
      <table:table-cell table:style-name="Table1.A1" office:value-type="string">
       <text:p text:style-name="Table_20_Heading">Test Case</text:p>
      </table:table-cell>
      <table:table-cell table:style-name="Table1.A1" office:value-type="string">
       <text:p text:style-name="Table_20_Heading">Input</text:p>
      </table:table-cell>
      <table:table-cell table:style-name="Table1.A1" office:value-type="string">
       <text:p text:style-name="Table_20_Heading">Expected Outcome</text:p>
      </table:table-cell>
     </table:table-row>
    </table:table-header-rows>
    <table:table-row>
     <table:table-cell table:style-name="Table1.A1" office:value-type="string">
      <text:p text:style-name="Table_20_Contents">Valid student ID</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.A1" office:value-type="string">
      <text:p text:style-name="Table_20_Contents">1005</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.A1" office:value-type="string">
      <text:p text:style-name="Table_20_Contents">Student loads successfully</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table1.A1" office:value-type="string">
      <text:p text:style-name="Table_20_Contents">Invalid student ID</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.A1" office:value-type="string">
      <text:p text:style-name="Table_20_Contents">9999</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.A1" office:value-type="string">
