 <office:body>
  <office:text text:use-soft-page-breaks="true">
   <text:sequence-decls>
    <text:sequence-decl text:display-outline-level="0" text:name="Illustration"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Table"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Text"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Drawing"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Figure"/>
   </text:sequence-decls>
   <text:h text:style-name="Heading_20_1" text:outline-level="1"><text:span text:style-name="Strong_20_Emphasis">Student Grade Calculator (SGC)</text:span></text:h>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">1. Introduction</text:span></text:h>
   <text:p text:style-name="Text_20_body">The Student Grade Calculator (SGC) is a <text:s/>command-line application designed to compute <text:span text:style-name="T1">and display </text:span>academic <text:span text:style-name="T1">grades</text:span> for university students. It <text:span text:style-name="T1">extracts</text:span> data from an SQLite database and calculates module grades and overall degree classifications.</text:p>
   <text:p text:style-name="Text_20_body">The <text:span text:style-name="T1">aims</text:span> of the application <text:span text:style-name="T1">are</text:span> to:</text:p>
   <text:list xml:id="list445940116" text:style-name="L1">
    <text:list-item>
     <text:p text:style-name="P11"><text:span text:style-name="T1">Display</text:span> detailed assessment-level information </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P11">Calculate <text:span text:style-name="T1">and display </text:span>module grades based on weighted assessments </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P12">Calculate <text:span text:style-name="T1">and display</text:span> degree <text:span text:style-name="T1">score and </text:span>classification based on weighted <text:span text:style-name="T1">modules</text:span> </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Key Functionalities</text:span></text:h>
   <text:list xml:id="list3396202919" text:style-name="L2">
    <text:list-item>
     <text:p text:style-name="P14">Load student data from a database </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P14">View individual assessment results </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P14">Calculate module grades using weighted contributions </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P14">Compute overall degree score and classification </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P13">Provide an interactive CLI for user navigation </text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">2. Class Diagrams (Textual UML Representation)</text:span></text:h>
   <text:section text:style-name="Sect1" text:name="code-block-viewer">
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| <text:s text:c="4"/>Assessment <text:s text:c="6"/>| &lt;&lt;abstract&gt;&gt;</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - assessmentID <text:s text:c="6"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - type <text:s text:c="14"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - moduleID <text:s text:c="10"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - awardedMarks <text:s text:c="6"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| - weight <text:s text:c="12"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| + getGrade() <text:s text:c="8"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>| + getContribution() <text:s/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="16"/>+----------+-----------+</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="27"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="8"/>---------------------------------------</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:s text:c="8"/>| <text:s text:c="36"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+---------------+ <text:s text:c="18"/>+------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s text:c="4"/>Exam <text:s text:c="5"/>| <text:s text:c="18"/>| <text:s text:c="2"/>Coursework <text:s text:c="4"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+---------------+ <text:s text:c="18"/>+------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - maxMarks <text:s text:c="3"/>| <text:s text:c="18"/>| (no extra fields)|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+---------------+ <text:s text:c="18"/>+------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s text:c="6"/>Module <text:s text:c="8"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - moduleID <text:s text:c="10"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - level <text:s text:c="13"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - assessments[] <text:s text:c="5"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - cachedScore <text:s text:c="7"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + getModuleScore() <text:s text:c="2"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + addAssessment() <text:s text:c="3"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text"><text:soft-page-break/>+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s text:c="6"/>Student <text:s text:c="7"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - studentID <text:s text:c="9"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| - modules[] <text:s text:c="9"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + getDegreeScore() <text:s text:c="2"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + getDegreeClass() <text:s text:c="2"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s/>DegreeCalculator <text:s text:c="3"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + calculateScore() <text:s text:c="2"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">| + classify() <text:s text:c="8"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| <text:s text:c="4"/>DegreeClass <text:s text:c="5"/>| &lt;&lt;enum&gt;&gt;</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
    <text:p text:style-name="Preformatted_20_Text">| FAIL, THIRD, etc. <text:s text:c="3"/>|</text:p>
    <text:p text:style-name="Preformatted_20_Text">+----------------------+</text:p>
   </text:section>
   <text:p text:style-name="Horizontal_20_Line"/>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">3. Class Descriptions</text:span></text:h>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">SGC </text:span></text:h>
   <text:p text:style-name="Text_20_body"><text:span text:style-name="T1">H</text:span>olds nested classes and database interaction methods. <text:span text:style-name="T1">Responsible for both logic and data access.</text:span></text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Assessment (Abstract Class)</text:span></text:h>
   <text:p text:style-name="Text_20_body">Defines a general structure for all assessments. It <text:span text:style-name="T1">requires the specific assignment types to </text:span>implement:</text:p>
   <text:list xml:id="list1092372308" text:style-name="L3">
    <text:list-item>
     <text:p text:style-name="P16"><text:span text:style-name="Source_20_Text">getGrade()</text:span> </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P15"><text:span text:style-name="Source_20_Text">getContribution()</text:span> </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Exam</text:span></text:h>
   <text:p text:style-name="Text_20_body">Extends <text:span text:style-name="Source_20_Text">Assessment</text:span>. <text:span text:style-name="T1">Exams have awarded and maximal marks. The former is divided by the and the ratio is converted to percentage.</text:span></text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Coursework</text:span></text:h>
   <text:p text:style-name="Text_20_body">Extends <text:span text:style-name="Source_20_Text">Assessment</text:span>. <text:span text:style-name="T1">For</text:span> coursework <text:span text:style-name="T1">(i.e reports and presentations)</text:span> marks are already in percentage form.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Module</text:span></text:h>
   <text:p text:style-name="Text_20_body"><text:span text:style-name="T1">U</text:span>niversity module<text:span text:style-name="T1">s</text:span> contain multiple assessments.</text:p>
   <text:list xml:id="list3872585411" text:style-name="L4">
    <text:list-item>
     <text:p text:style-name="P18">Calculates total grade using <text:span text:style-name="T1">the </text:span>weighted <text:span text:style-name="T1">assignments </text:span>contributions </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P17">Implements caching (<text:span text:style-name="Source_20_Text">cachedScore</text:span>) for performance optimization </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:soft-page-break/><text:span text:style-name="Strong_20_Emphasis">Student</text:span></text:h>
   <text:p text:style-name="Text_20_body">Represents a student with multiple modules.</text:p>
   <text:list xml:id="list389710706" text:style-name="L5">
    <text:list-item>
     <text:p text:style-name="P20">Provides methods to calculate degree score and classification </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P19">Acts as a container for module data </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">DegreeCalculator</text:span></text:h>
   <text:p text:style-name="Text_20_body">Contains static logic for:</text:p>
   <text:list xml:id="list4229751410" text:style-name="L6">
    <text:list-item>
     <text:p text:style-name="P22">Calculating final degree score </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P22">Applying weighting rules (30% Level 5, 70% Level 6) </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P21">Dropping the lowest module </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">DegreeClass (Enum)</text:span></text:h>
   <text:p text:style-name="Text_20_body">Defines classification boundaries:</text:p>
   <text:list xml:id="list2577771576" text:style-name="L7">
    <text:list-item>
     <text:p text:style-name="P23">Fail, Third Class, Second Class Second Division, Second Class First Division, First<text:line-break/>Encapsulates classification logic and descriptions. </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Main</text:span></text:h>
   <text:p text:style-name="Text_20_body">Handles CLI interaction:</text:p>
   <text:list xml:id="list757365251" text:style-name="L8">
    <text:list-item>
     <text:p text:style-name="P25">User input validation </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P25">Menu navigation </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P24">Displaying formatted outputs </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">4. OOP Principles</text:span></text:h>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Encapsulation</text:span></text:h>
   <text:p text:style-name="Text_20_body">All class fields are private or protected and accessed via getters. This prevents unintended modification of internal state.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Inheritance</text:span></text:h>
   <text:p text:style-name="Text_20_body"><text:span text:style-name="Source_20_Text">Exam</text:span> and <text:span text:style-name="Source_20_Text">Coursework</text:span> inherit from <text:span text:style-name="Source_20_Text">Assessment</text:span>.</text:p>
   <text:p text:style-name="Text_20_body">Benefits:</text:p>
   <text:list xml:id="list4213463939" text:style-name="L9">
    <text:list-item>
     <text:p text:style-name="P27">Code reuse </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P27">Shared structure </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P26">Consistent interface </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Polymorphism</text:span></text:h>
   <text:p text:style-name="Text_20_body"><text:span text:style-name="T1">A</text:span>ll assessments <text:span text:style-name="T1">are treated</text:span> <text:span text:style-name="T1">the same</text:span>, <text:span text:style-name="T1">despite the differences in the calculation of</text:span> <text:s/><text:span text:style-name="Source_20_Text">Exam</text:span> and <text:span text:style-name="Source_20_Text">Coursework</text:span>.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:soft-page-break/><text:span text:style-name="Strong_20_Emphasis">Abstraction</text:span></text:h>
   <text:p text:style-name="Text_20_body"><text:span text:style-name="Source_20_Text">Assessment</text:span> is abstract and hides implementation details.<text:line-break/>Users of the class do not need to know:</text:p>
   <text:list xml:id="list23648179" text:style-name="L10">
    <text:list-item>
     <text:p text:style-name="P29">How grades are calculated </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P28">Whether it is an exam or coursework </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">5. CLI Design</text:span></text:h>
   <text:p text:style-name="Text_20_body">The application uses a menu-<text:span text:style-name="T1">styled</text:span> <text:span text:style-name="T1">CLI</text:span>.</text:p>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">User Flow</text:span></text:h>
   <text:list xml:id="list2686654656" text:style-name="L11">
    <text:list-item>
     <text:p text:style-name="P31">User enters Student ID <text:span text:style-name="T1">from the available range </text:span>(validated against database), <text:span text:style-name="T1">or 0 to exit</text:span></text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P31"><text:span text:style-name="T1">A m</text:span>enu <text:span text:style-name="T1">appears with the following </text:span>options, <text:span text:style-name="T1">and the user selects one or enters 0 to move back</text:span>: </text:p>
     <text:list>
      <text:list-item>
       <text:p text:style-name="P31">Assessment </text:p>
      </text:list-item>
      <text:list-item>
       <text:p text:style-name="P31">Module </text:p>
      </text:list-item>
      <text:list-item>
       <text:p text:style-name="P31">Degree </text:p>
      </text:list-item>
     </text:list>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P30"><text:span text:style-name="T2">If Assesment or</text:span> <text:span text:style-name="T2">Module option is selected, the ranges of available Ids are listed and the user <text:s text:c="2"/></text:span>inputs <text:span text:style-name="T2">the </text:span>relevant ID. </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_3" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis">Output</text:span></text:h>
   <text:p text:style-name="Text_20_body">Formatted tables displaying:</text:p>
   <text:list xml:id="list2539085412" text:style-name="L12">
    <text:list-item>
     <text:p text:style-name="P33">Assessment details <text:span text:style-name="T2">and grade</text:span></text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P34">Module details <text:span text:style-name="T2">and grade</text:span> </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P32">Degree <text:span text:style-name="T2">score and </text:span>classification</text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">Testing</text:span></text:h>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">1. Testing Strategy</text:span></text:h>
   <text:p text:style-name="Text_20_body">The application was tested using <text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T4">u</text:span></text:span><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">ser input testing</text:span></text:span></text:p>
   <text:p text:style-name="Text_20_body">Focus areas:</text:p>
   <text:list xml:id="list2671899661" text:style-name="L13">
    <text:list-item>
     <text:p text:style-name="P36">Correct grade calculations </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P36">Handling missing data </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P36">Input validation </text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P35">Database query correctness </text:p>
    </text:list-item>
   </text:list>
   <text:h text:style-name="Heading_20_2" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis">2. Test Cases</text:span></text:h>
   <table:table table:name="Table1" table:style-name="Table1">
